# .env.example — Example environment variables for local development
# Copy this to `.env` and fill values locally (do NOT commit .env).

# Notes:
# - Keep this file in the repo (safe to commit) so developers know required variables.
# - Do NOT put real secrets in the repository. Use CI secrets store for GitHub/GitLab.
# - Example boolean values: true/false (case-insensitive). For feature flags use "true"/"false".

# --- Environment + machine ---
# Which environment are we targeting for local runs? e.g.: local, test, staging
ENV=test

# Helpful for tagging logs locally if running multiple machines or runs
MACHINE=machine1

# Host/short name or base domain (used to derive full API base URLs in your config loader)
WP_HOST=amps

# --- WooCommerce API credentials ---
# Fill with WooCommerce Consumer Key and Secret for local testing
WC_KEY=
WC_SECRET=

# --- Database credentials (sensitive) ---
# These should be provided via CI secrets in staging/production
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_TABLE_PREFIX=

# --- System config ---
# Ensure UTF-8 encoding in Python IO
PYTHONIOENCODING=utf-8

# Optional: enforce presence of .env in local runs (set to true only if you want fails locally)
# In CI set REQUIRE_ENV=true to fail when .env is missing or required vars not present.
REQUIRE_ENV=false

# --- New logging-related toggles ---
# Enable structured JSON log output (json-lines). Set to true in CI to produce machine-friendly artifacts.
# Note: when enabled, JSONL files are written to: <log_root>/<ENV>/test_debug_structured_<YYYYMMDD_HHMMSS>.jsonl
ENABLE_STRUCTURED_LOGS=true

# Keep this many structured JSONL files in the logs folder. Default = 3 if unset.
KEEP_STRUCTURED_LOGS=3

# ---------------------------------------------------------------------------
# Performance report control
# ---------------------------------------------------------------------------
# Default number of iterations for performance tests when CLI option not supplied.
# CI or local users may set PERF_ITERATIONS in .env or environment; CLI (--perf-iterations) takes precedence.
PERF_ITERATIONS=5

# If "true", pretty-print JSONL (multi-line). Default = false (compact single-line JSON).
ENABLE_JSON_PRETTY=true

# Include request payloads in logs (masked). Use with care.
# Default: false (omit payloads from structured logs). Set to true in CI only when you need deeper artifacts.
LOG_PAYLOADS=false

# Control automatic redaction of sensitive fields (passwords, tokens, keys).
# Default: true — recommended for CI and most runs to avoid leaking secrets into logs/artifacts.
# Set to false only when you intentionally need raw values for debugging (use with caution).
REDACT_SENSITIVE_FIELDS=true

# Force-disable emojis (overrides CI auto-detection).
DISABLE_LOG_EMOJIS=false

# =====================================================================
# LOGGING & REPORTING CONFIGURATION (SHARED, OPTIONAL OVERRIDES)
# =====================================================================

# ---------------------------------------------------------------------
# LOG_DIR
# ---------------------------------------------------------------------
# Root directory for structured JSONL logs.
# IMPORTANT:
#   - If unset, the framework picks paths dynamically based on the test team:
#       reports/<team>/logs/
#   - You can override this manually to force a single location (CI or debugging).
#
# Examples:
# LOG_DIR=/absolute/path/logs
# LOG_DIR=C:\work\artifacts\logs
#
# To use dynamic per-team paths, leave this commented out.
# LOG_DIR=


# When true, schema smoke tests will fail when a list endpoint returns an empty list.
# CLI flag (--fail-on-empty-list) takes precedence over this env var.
FAIL_ON_EMPTY_LIST=false

# ---------------------------------------------------------------------------
# Optional helper: session id (if you want a CI-provided session id)
# ---------------------------------------------------------------------------
# If you want a stable job/session id embedded in logs/reports (instead of the generated SESSION_ID),
# set this in the CI job. Otherwise conftest will generate a SESSION_ID automatically.
# Example: SESSION_ID=${{ github.run_id }}
SESSION_ID=

# ---------------------------------------------------------------------------
# Auto-generate Allure HTML report after pytest run
# ---------------------------------------------------------------------------
AUTO_ALLURE_REPORT=true


# ---------------------------------------------------------------------------
#  Control strictness of API entity discovery during pytest collection.
# ---------------------------------------------------------------------------
# When enabled, pytest will FAIL FAST if:
#   - an expected entity helper is found but no matching DAO exists
#   - a delete method cannot be resolved for an entity
#   - an entity is partially discovered (helper without DAO, etc.)
#
# Default: false — discovery is permissive and logs warnings only.
# Recommended:
#   - false for local development and onboarding
#   - true for CI to catch broken or incomplete entities early
#
# Valid values: 1 / true / yes / on (enable), 0 / false / no / off (disable)
STRICT_ENTITY_DISCOVERY=false
