# This ensures:
  #
  #    ✅ All text files use LF (Unix line endings) in the repository
  #    ✅ Git auto-converts CRLF → LF when committing from Windows
  #    ✅ Scripts work correctly in Linux CI runners

* text=auto

*.py     text eol=lf
*.sh     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.md     text eol=lf
Dockerfile text eol=lf

